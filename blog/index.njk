---
permalink: /
---
<h1>{{ site.title }}</h1>
<ul class="posts">
{%- for post in collections.posts %}
<li>
  <a href="{{ post.url | url }}">{{ post.data.title }}</a>
  {%- if post.data.postDate %} <span class="meta">{{ post.data.postDate | isodate }}</span>{% endif %}
  <p>{{ post.data.description }}</p>
</li>
{%- else %}
<li><p>No posts yet.</p></li>
{%- endfor %}
</ul>
