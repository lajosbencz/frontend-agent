<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title or site.title }}</title>
<meta name="description" content="{{ description or site.description }}">
{%- set url = canonical_url or (site.url + (page.url | url)) %}
<link rel="canonical" href="{{ url }}">
<meta property="og:type" content="{% if page.url == '/' %}website{% else %}article{% endif %}">
<meta property="og:title" content="{{ title or site.title }}">
<meta property="og:description" content="{{ description or site.description }}">
<meta property="og:url" content="{{ url }}">
{%- if ogImage %}
<meta property="og:image" content="{{ site.url }}{{ ogImage | url }}">
{%- endif %}
<meta name="twitter:card" content="{% if ogImage %}summary_large_image{% else %}summary{% endif %}">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
<header class="site"><a href="{{ '/' | url }}">{{ site.title }}</a></header>
<main>
{%- if page.url == '/' %}
{{ content | safe }}
{%- else %}
<article>
<h1>{{ title }}</h1>
{%- if postDate %}
<p class="meta"><time datetime="{{ postDate | isodate }}">{{ postDate | isodate }}</time></p>
{%- endif %}
{{ content | safe }}
</article>
{%- endif %}
</main>
<footer class="site">{{ site.author }} &middot; <a href="{{ '/' | url }}">all posts</a></footer>
</body>
</html>
